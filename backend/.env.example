NODE_ENV=development
PORT=3000

# When running via docker compose, host is the service name "postgres" and port 5432.
# When running the API locally (npm run start:dev) against the dockerized DB, use localhost:5433
# (Postgres is mapped to 5433 on the host to avoid clashing with a local Postgres install on 5432).
DATABASE_URL=postgresql://checkout_user:checkout_password@localhost:5433/payment_checkout?schema=public

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

CORS_ORIGIN=*

# Wompi Sandbox (UAT) credentials - see docs.wompi.co
WOMPI_UAT_URL=https://api.co.uat.wompi.dev/v1
WOMPI_SANDBOX_URL=https://api-sandbox.co.uat.wompi.dev/v1
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_KEY=
WOMPI_INTEGRITY_KEY=
